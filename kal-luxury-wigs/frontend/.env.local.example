# Copy this file to .env.local for local development.
#
# This is the ONLY thing the frontend needs to know about directly — it's
# the URL of your backend API. Everything else (shop name, TeleBirr number,
# CBE details, Google Maps key) is fetched from the backend's
# /api/config/public endpoint at runtime, so you only ever edit those once,
# in backend/.env.

NEXT_PUBLIC_API_URL=http://localhost:5000

# Your site's own public URL — used for Open Graph / social share previews.
# Defaults to localhost, which is fine until you deploy.
NEXT_PUBLIC_SITE_URL=http://localhost:3000
