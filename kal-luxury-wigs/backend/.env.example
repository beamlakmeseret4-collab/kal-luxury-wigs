# ============================================
# KAL LUXURY WIG SHOP — BACKEND ENVIRONMENT
# Copy this file to .env and fill in real values.
# Lines marked REQUIRED must be set before launch.
# Everything else has a safe default or is optional.
# ============================================

NODE_ENV=development
PORT=5000

# REQUIRED — MongoDB connection string.
# Local dev:   mongodb://localhost:27017/kal-luxury-wigs
# Production:  get a free cluster at https://www.mongodb.com/cloud/atlas
MONGODB_URI=mongodb://localhost:27017/kal-luxury-wigs

# REQUIRED — long random string used to sign login tokens.
# Generate one with: node -e "console.log(require('crypto').randomBytes(48).toString('hex'))"
JWT_SECRET=replace-this-with-a-long-random-string
JWT_EXPIRE=30d
ADMIN_JWT_EXPIRE=2d

# REQUIRED — the deployed URL of your frontend (for CORS).
# Local dev default shown below.
FRONTEND_URL=http://localhost:3000

# --- Shop identity (shown in emails, receipts, footer, admin) ---
SHOP_NAME="Kal Luxury Wig Shop"
SHOP_EMAIL=hello@kalluxurywigshop.com
SHOP_PHONE=+251900000000
SHOP_ADDRESS="Bole Road, Addis Ababa, Ethiopia"
SHOP_PICKUP_INSTRUCTIONS="Open Mon-Sat, 9am-7pm. Call ahead so we can have your order ready."

# Flat delivery fee in ETB, added to the order total for delivery orders
# (0 = free delivery). Leave blank or 0 if you haven't decided on a fee yet.
DELIVERY_FEE=0

# --- REQUIRED before launch: payment display details ---
# These are shown to the customer at checkout. Nothing here needs a merchant
# API or approval process — the customer pays you directly through their own
# TeleBirr/CBE app, then uploads a screenshot as proof.
TELEBIRR_ACCOUNT_NAME="Kal Luxury Wig Shop"
TELEBIRR_NUMBER=+251900000000
CBE_ACCOUNT_NAME="Kal Luxury Wig Shop"
CBE_ACCOUNT_NUMBER=1000XXXXXXXX
CBE_BRANCH="Bole Branch"

# --- REQUIRED before launch: Google Maps ---
# Get a key at https://console.cloud.google.com (enable "Maps JavaScript API"
# and "Geocoding API"). Until this is set, delivery orders fall back
# automatically to a plain text address field, so the site still works.
GOOGLE_MAPS_API_KEY=

# --- Image uploads ---
# Local disk storage works out of the box with ZERO configuration below —
# uploaded images are served from this server at /uploads/...
# Fill these in ONLY if you'd rather host images on Cloudinary instead
# (recommended once you deploy, since most hosts wipe local disk on redeploy).
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=

# --- Optional: instant order alerts via Telegram ---
# Leave blank to disable. To enable: message @BotFather to create a bot and
# get TELEGRAM_BOT_TOKEN, then message @userinfobot to get your chat id.
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# --- Optional: email notifications to admin on new orders ---
# Leave blank to disable.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
ADMIN_NOTIFY_EMAIL=

# --- One-time admin bootstrap ---
# Used only by `npm run create-admin`, which creates your first admin login.
# Change the password immediately after your first login.
FIRST_ADMIN_NAME=Admin
FIRST_ADMIN_PHONE=+251900000000
FIRST_ADMIN_PASSWORD=change-this-immediately
